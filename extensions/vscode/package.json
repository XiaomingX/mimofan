{
  "name": "mimofan-vscode",
  "displayName": "Mimofan",
  "description": "Official Mimofan VS Code integration scaffold for local runtime attach and terminal launch.",
  "version": "0.8.53",
  "publisher": "mimofan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/XiaomingX/mimofan.git",
    "directory": "extensions/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mimofan.openTerminal",
    "onCommand:mimofan.startRuntime",
    "onCommand:mimofan.checkRuntime",
    "onCommand:mimofan.refreshAgentView",
    "onCommand:mimofan.refreshSnapshots",
    "onCommand:mimofan.openRuntimeDocs",
    "onView:mimofan.runtimeStatus"
  ],
  "main": "./out/extension.js",
  "files": [
    "out",
    "media",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mimofan.openTerminal",
        "title": "Mimofan: Open Terminal"
      },
      {
        "command": "mimofan.startRuntime",
        "title": "Mimofan: Start Local Runtime"
      },
      {
        "command": "mimofan.checkRuntime",
        "title": "Mimofan: Check Runtime"
      },
      {
        "command": "mimofan.refreshAgentView",
        "title": "Mimofan: Refresh Agent View"
      },
      {
        "command": "mimofan.refreshSnapshots",
        "title": "Mimofan: Refresh Restore Points"
      },
      {
        "command": "mimofan.openRuntimeDocs",
        "title": "Mimofan: Open Runtime API Docs"
      }
    ],
    "configuration": {
      "title": "Mimofan",
      "properties": {
        "mimofan.commandPath": {
          "type": "string",
          "default": "mimofan",
          "description": "Command or absolute path used to launch Mimofan."
        },
        "mimofan.runtimeHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Local host used for Mimofan runtime attach checks."
        },
        "mimofan.runtimePort": {
          "type": "number",
          "default": 7878,
          "minimum": 1,
          "maximum": 65535,
          "description": "Local port used for Mimofan runtime attach checks."
        },
        "mimofan.runtimeToken": {
          "type": "string",
          "default": "",
          "description": "Optional bearer token for authenticated runtime endpoints."
        },
        "mimofan.agentViewRefreshIntervalSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 300,
          "description": "Seconds between read-only Agent View refreshes. Set to 0 to disable automatic refresh."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mimofan",
          "title": "Mimofan",
          "icon": "media/mimofan.svg"
        }
      ]
    },
    "views": {
      "mimofan": [
        {
          "type": "webview",
          "id": "mimofan.runtimeStatus",
          "name": "Agent View"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "check": "pnpm compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.0",
    "typescript": "^5.9.3"
  }
}
