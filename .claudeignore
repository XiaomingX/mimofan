# ============================================
# mimofan .claudeignore
# 排除 AI 不需要读取的文件，减少 token 浪费
# ============================================

# ── 排除辅助/入口 crate（保留核心引擎和工具链）──
crates/app-server/
crates/cli/
crates/whaleflow/

# ── 构建产物 ──
target/

# ── 前端 / 非 Rust 代码 ──
web/
npm/
extensions/
integrations/

# ── Lock 文件（数千行，浪费 token）──
Cargo.lock
package-lock.json
web/package-lock.json
extensions/vscode/package-lock.json
integrations/*/package-lock.json
flake.lock

# ── 大型生成文件 ──
crates/tui/assets/model_catalog.bundled.json
crates/config/assets/models_dev.bundled.json

# ── 测试文件（不影响代码理解，减少 token 浪费）──
crates/*/tests/
crates/tui/tests/
crates/tui/src/tui/ui/tests.rs
crates/tui/src/tui/app/tests.rs
crates/tui/src/config/tests.rs
crates/tui/src/runtime_api/tests.rs
crates/tui/src/tools/subagent/tests.rs
crates/tui/src/core/engine/tests.rs
crates/tui/src/mcp/tests.rs
crates/tui/src/runtime_threads/tests.rs
crates/tui/src/tools/shell/tests.rs
crates/tui/src/tui/history/tests.rs
crates/tui/src/test_support.rs
crates/tui/src/tools/test_runner.rs
crates/config/src/tests.rs
crates/config/src/route/tests.rs
crates/config/src/route/conformance_tests.rs
crates/config/src/catalog/tests.rs
crates/config/src/pricing/tests.rs

# ── 超大文件（稳定模块，摘要见 CLAUDE.md）──
crates/tui/src/localization.rs
crates/tui/src/prompts.rs
crates/tui/src/tui/widgets/mod.rs
crates/tui/src/tui/views/mod.rs

# ── AI 记忆文件（已自动注入上下文，重复读取浪费 token）──
**/CLAUDE.local.md

# ── 根目录非核心文件 ──
AGENTS.md
ARCHITECTURE_MASTER_PLAN.md
ARCHITECTURE_REFORM_PLAN*.md
CONSTANTS_AND_CONFIG_CONSOLIDATION.md
STABILITY_RISKS_ANALYSIS.md
USER_GUIDE.md
settings.example.json

# ── 变更日志（历史记录，不影响代码理解）──
CHANGELOG.md
docs/CHANGELOG_ARCHIVE.md
crates/tui/CHANGELOG.md

# ── 非核心文档（不影响代码理解）──
docs/rfcs/
docs/evidence/
docs/skills/
docs/architecture/
docs/ARCHITECTURE.md
docs/GUIDE.md
docs/INSTALL.md
docs/DOCKER.md
docs/FLEET.md
