# ============================================
# mimofan .claudeignore
# 策略：仅保留 tui + cli 及其依赖 crate 的源码
# 排除一切与 tui/cli 无关的路径，节省 token 消耗
# ============================================

# ── 与 tui/cli 无关的 crate ──
# tui 依赖: config, execpolicy, protocol, release, secrets, tools
# cli 依赖: agent, app-server, config, execpolicy, mcp, release, secrets, state
# core/hooks 是 app-server 的传递依赖
# 唯一无关的 crate:
crates/whaleflow/

# ── 构建产物 ──
target/
node_modules/

# ── 前端 / 非 Rust 代码（与 tui/cli 完全无关）──
web/
npm/
extensions/
integrations/

# ── Lock 文件（数千行，零信息密度）──
Cargo.lock
pnpm-lock.yaml
pnpm-workspace.yaml
package-lock.json
flake.lock

# ── 大型生成/数据文件 ──
crates/tui/assets/model_catalog.bundled.json
crates/config/assets/models_dev.bundled.json
config.example.toml

# ── 超大稳定模块（摘要见 CLAUDE.md）──
crates/tui/src/localization.rs
crates/tui/src/prompts.rs
crates/tui/src/tui/widgets/mod.rs
crates/tui/src/tui/views/mod.rs

# ── 测试文件（统一模式，不影响代码理解）──
crates/*/tests/
**/tests.rs
**/conformance_tests.rs
**/test_support.rs
**/test_runner.rs

# ── 文档（全部排除，核心信息已在 CLAUDE.md）──
docs/
README.md

# ── 变更日志与历史记录 ──
CHANGELOG.md
crates/tui/CHANGELOG.md

# ── AI 记忆文件与本地设置 ──
**/CLAUDE.local.md
AGENTS.md
settings.example.json

# ── Nix 配置 ──
flake.nix
nix/

# ── 部署与容器 ──
deploy/
Dockerfile
.devcontainer/
.cnb.yml
.dockerignore

# ── GitHub 模板/工作流 ──
.github/

# ── 资源文件（图片等）──
assets/

# ── 脚本与工作流 ──
scripts/
workflows/

# ── Benchmark 结果 ──
benchmark_results/

# ── 非核心根文件 ──
package.json
.mailmap
.gitattributes
rust-toolchain.toml
.env.example

# ── 临时/生成文件 ──
*.sh
*.cmd
*.log
