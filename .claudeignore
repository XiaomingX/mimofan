# ── Nix 配置 ──
flake.nix
nix/

# ── 部署配置 ──
deploy/
Dockerfile
.devcontainer/
.cnb.yml

# ── GitHub 模板/工作流 ──
.github/workflows/
.github/ISSUE_TEMPLATE/
.github/PULL_REQUEST_TEMPLATE.md
.github/APPROVED_CONTRIBUTORS
.github/AUTHOR_MAP
.github/CODEOWNERS
.github/dependabot.yml
.github/FUNDING.yml

# ── 资源文件（图片等，不影响代码理解）──
assets/

# ── 脚本文件（发布/部署/CI 脚本，不影响代码理解）──
scripts/

# ── 工作流定义（JS/Star 脚本）──
workflows/

# ── 临时/生成文件 ──
*.sh
*.cmd

# ── Git 内部目录 ──
.git/

# ── 项目本地配置 ──
.env.example
.mailmap
.gitattributes

# ============================================
# 保留（不排除）— Claude Code 核心组件：
# - crates/tui/          TUI 终端界面
# - crates/core/         对话引擎、会话管理
# - crates/agent/        模型注册表、路由解析
# - crates/config/       配置管理
# - crates/tools/        工具系统（shell、文件等）
# - crates/mcp/          MCP 工具集成
# - crates/hooks/        工具执行钩子
# - crates/execpolicy/   执行策略引擎
# - crates/protocol/     协议类型定义
# - crates/state/        会话持久化（SQLite）
# - crates/secrets/      密钥管理
# - crates/release/      发布工具
# - config.example.toml  配置示例
# - CLAUDE.md            项目级 AI 指引
# - Cargo.toml           工作区配置
# ============================================
