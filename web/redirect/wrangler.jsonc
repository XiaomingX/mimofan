{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "mimofan-web",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "observability": { "enabled": true },
  "routes": [
    { "pattern": "mimofan.com", "custom_domain": true },
    { "pattern": "www.mimofan.com", "custom_domain": true }
  ]
}
