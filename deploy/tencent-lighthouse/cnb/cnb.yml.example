# Historical CNB config template for the Tencent Lighthouse remote-first path.
# The active pipeline now lives in the repository-root .cnb.yml so the GitHub
# -> CNB one-way mirror cannot overwrite CNB-only pipeline edits.

main:
  push:
    - docker:
        image: node:22-bookworm
      stages:
        - name: feishu bridge tests
          script: |
            npm install -g pnpm
            cd integrations/feishu-bridge
            pnpm install
            pnpm check
            pnpm test

    - docker:
        image: rust:1.88-bookworm
      stages:
        - name: release version check
          script: |
            ./scripts/release/check-versions.sh

  web_trigger_lighthouse:
    - docker:
        image: cnbcool/default-build-env:latest
      stages:
        - name: deploy to lighthouse
          script: |
            set -euo pipefail

            : "${LIGHTHOUSE_HOST:?Set LIGHTHOUSE_HOST in CNB secrets}"
            : "${LIGHTHOUSE_SSH_TARGET:?Set LIGHTHOUSE_SSH_TARGET in CNB secrets}"
            : "${LIGHTHOUSE_SSH_PRIVATE_KEY:?Set LIGHTHOUSE_SSH_PRIVATE_KEY in CNB secrets}"

            if ! command -v ssh >/dev/null 2>&1 || ! command -v ssh-keyscan >/dev/null 2>&1; then
              apt-get update
              apt-get install -y openssh-client
            fi

            LIGHTHOUSE_SSH_PORT="${LIGHTHOUSE_SSH_PORT:-22}"
            MIMOFAN_REPO_BRANCH="${MIMOFAN_REPO_BRANCH:-main}"
            MIMOFAN_REPO_URL="${MIMOFAN_REPO_URL:-https://cnb.cool/mimofan.net/mimofan.git}"

            install -m 700 -d ~/.ssh
            printf '%s\n' "$LIGHTHOUSE_SSH_PRIVATE_KEY" > ~/.ssh/id_ed25519
            chmod 600 ~/.ssh/id_ed25519
            ssh-keyscan -p "$LIGHTHOUSE_SSH_PORT" -H "$LIGHTHOUSE_HOST" >> ~/.ssh/known_hosts

            ssh -p "$LIGHTHOUSE_SSH_PORT" "$LIGHTHOUSE_SSH_TARGET" \
              "MIMOFAN_REPO_BRANCH='$MIMOFAN_REPO_BRANCH' MIMOFAN_REPO_URL='$MIMOFAN_REPO_URL' bash -s" <<'REMOTE'
            set -euo pipefail

            if [ ! -d /opt/whalebro/mimofan/.git ]; then
              sudo -u mimofan git clone --branch "$MIMOFAN_REPO_BRANCH" "$MIMOFAN_REPO_URL" /opt/whalebro/mimofan
            fi

            cd /opt/whalebro/mimofan
            if [ -n "$(sudo -u mimofan git status --porcelain)" ]; then
              echo "Refusing to deploy over a dirty /opt/whalebro/mimofan checkout." >&2
              sudo -u mimofan git status --short
              exit 1
            fi

            sudo -u mimofan git fetch --all --tags
            if sudo -u mimofan git rev-parse --verify --quiet "refs/remotes/origin/$MIMOFAN_REPO_BRANCH" >/dev/null; then
              sudo -u mimofan git checkout -B "$MIMOFAN_REPO_BRANCH" "origin/$MIMOFAN_REPO_BRANCH"
            elif sudo -u mimofan git rev-parse --verify --quiet "refs/tags/$MIMOFAN_REPO_BRANCH" >/dev/null; then
              sudo -u mimofan git checkout --detach "$MIMOFAN_REPO_BRANCH"
            else
              sudo -u mimofan git checkout "$MIMOFAN_REPO_BRANCH"
              sudo -u mimofan git pull --ff-only
            fi

            sudo -iu mimofan bash -lc '
              set -euo pipefail
              . "$HOME/.cargo/env"
              cd /opt/whalebro/mimofan
              cargo install --path crates/cli --locked --force
              cargo install --path crates/tui --locked --force
            '

            sudo bash scripts/tencent-lighthouse/install-services.sh
            sudo systemctl restart mimofan-runtime
            sudo systemctl restart mimofan-feishu-bridge
            sudo bash scripts/tencent-lighthouse/doctor.sh
            REMOTE
