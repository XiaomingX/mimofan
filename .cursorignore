# ============================================
# CodeWhale .claudeignore
# 优化：排除 AI 不需要读取的文件，减少 token 浪费
# ============================================

# ── 构建产物 ──
target/

# ── 前端 / 非 Rust 代码 ──
web/
npm/
extensions/
integrations/

# ── Lock 文件（数千行，浪费 token）──
Cargo.lock
package-lock.json
web/package-lock.json
extensions/vscode/package-lock.json
integrations/*/package-lock.json
flake.lock

# ── 大型生成文件 ──
crates/tui/assets/model_catalog.bundled.json
crates/config/assets/models_dev.bundled.json

# ── AI 记忆文件（已自动注入上下文，重复读取浪费 token）──
**/CLAUDE.local.md

# ── 变更日志（历史记录，不影响代码理解）──
CHANGELOG.md
docs/CHANGELOG_ARCHIVE.md
crates/tui/CHANGELOG.md

# ── 非核心文档（不影响代码理解）──
docs/rfcs/                    # 历史 RFC 设计文档
docs/evidence/                # 审计证据材料
docs/skills/                  # 技能市场文档
docs/architecture/            # 架构子文档（已有 ARCHITECTURE_CN.md）
docs/ARCHITECTURE.md          # 英文版，已有中文版 ARCHITECTURE_CN.md
docs/GUIDE.md                 # 用户指南（已有 USAGE_CN.md）
docs/INSTALL.md               # 安装指南（802 行，不影响代码理解）
docs/DOCKER.md                # Docker 部署
docs/FLEET.md                 # 舰队编排（542 行，实验性功能）
docs/RUNTIME_API.md           # 运行时 API（665 行）
docs/AGENT_RUNTIME.md         # 代理运行时
docs/RECURSIVE_SELF_IMPROVEMENT.md
docs/CNB_MIRROR.md
docs/REBRAND.md
docs/RECEIPTS.md
docs/CLAUDE_PLUGIN_COMPAT.md
docs/ACP_REGISTRY_SUBMISSION.md
docs/CLASSROOM_INSTALL.md
docs/ACCESSIBILITY.md
docs/CONTRIBUTORS.md
docs/MODEL_LAB.md
docs/TOOL_LIFECYCLE.md
docs/WORKROOM_SECURITY.md
docs/WORKROOM_ARCHITECTURE.md
docs/WHALEFLOW_AUTHORING.md
docs/LEGACY_PATHS.md
docs/SANDBOX.md
docs/SKILL_INVOCATION_DESIGN.md
docs/CLAUDE.local.md
docs/memory/                  # 记忆系统文档
benchmark_results/
ARCHITECTURE_REFORM.md        # 改进计划（已完成的阶段性文档）
DEEPSEEK_CACHE_AUDIT.md       # 审计文档
HIGHLIGHTS.md
USERGUIDE.md
SECURITY.md
docs/RELEASE_CHECKLIST.md
docs/RELEASE_RUNBOOK.md
docs/OPERATIONS_RUNBOOK.md
docs/V0_8_61_EXECUTION.md
docs/V0865_RELEASE_LEDGER.md
docs/V0865_REMAINING_AGENT_PROMPT.md
README.md                     # GitHub 展示文件，不影响代码理解

# ── Nix 配置 ──
flake.nix
nix/

# ── 部署配置 ──
deploy/
Dockerfile
.devcontainer/
.cnb.yml

# ── GitHub 模板/工作流 ──
.github/workflows/
.github/ISSUE_TEMPLATE/
.github/PULL_REQUEST_TEMPLATE.md
.github/APPROVED_CONTRIBUTORS
.github/AUTHOR_MAP
.github/CODEOWNERS
.github/dependabot.yml
.github/FUNDING.yml

# ── 资源文件（图片等，不影响代码理解）──
assets/

# ── 脚本文件（发布/部署/CI 脚本，不影响代码理解）──
scripts/

# ── 工作流定义（JS/Star 脚本）──
workflows/

# ── 临时/生成文件 ──
*.sh
*.cmd
result.json
count_deps.py
project_overhaul_prompt.md

# ── 项目本地配置 ──
.codewhale/
.env.example
.mailmap
.gitattributes

# ============================================
# 保留（不排除）：
# - crates/              Rust 源代码（含 prompts/ 提示词模板）
# - docs/ 核心文档       ARCHITECTURE_CN.md, CONFIGURATION.md, PROVIDERS.md,
#                        SUBAGENTS.md, MCP.md, MODES.md, USAGE_CN.md,
#                        TOOL_SURFACE.md, KEYBINDINGS.md, MEMORY.md
# - config.example.toml  配置示例
# - AGENTS.md            AI 代理工作规范
# - CLAUDE.md            项目级 AI 指引
# - Cargo.toml           工作区配置
# ============================================
