# ============================================
# mimofan .claudeignore
# 排除 AI 不需要读取的文件，减少 token 浪费
# ============================================

# ── 构建产物 ──
target/

# ── 前端 / 非 Rust 代码 ──
web/
npm/
extensions/
integrations/

# ── Lock 文件（数千行，浪费 token）──
Cargo.lock
package-lock.json
web/package-lock.json
extensions/vscode/package-lock.json
integrations/*/package-lock.json
flake.lock

# ── 大型生成文件 ──
crates/tui/assets/model_catalog.bundled.json
crates/config/assets/models_dev.bundled.json

# ── 测试文件（不影响代码理解，减少 token 浪费）──
crates/*/tests/
crates/tui/tests/
crates/tui/src/tui/ui/tests.rs
crates/tui/src/tui/app/tests.rs
crates/tui/src/config/tests.rs
crates/tui/src/runtime_api/tests.rs
crates/tui/src/tools/subagent/tests.rs
crates/tui/src/core/engine/tests.rs
crates/config/src/tests.rs
crates/config/src/route/tests.rs

# ── AI 记忆文件（已自动注入上下文，重复读取浪费 token）──
**/CLAUDE.local.md

# ── 变更日志（历史记录，不影响代码理解）──
CHANGELOG.md
docs/CHANGELOG_ARCHIVE.md
crates/tui/CHANGELOG.md

# ── 非核心文档（不影响代码理解）──
docs/rfcs/
docs/evidence/
docs/skills/
docs/architecture/
docs/ARCHITECTURE.md
docs/GUIDE.md
docs/INSTALL.md
docs/DOCKER.md
docs/FLEET.md
docs/RUNTIME_API.md
docs/AGENT_RUNTIME.md
docs/RECURSIVE_SELF_IMPROVEMENT.md
docs/CNB_MIRROR.md
docs/RECEIPTS.md
docs/CLAUDE_PLUGIN_COMPAT.md
docs/ACP_REGISTRY_SUBMISSION.md
docs/CLASSROOM_INSTALL.md
docs/ACCESSIBILITY.md
docs/CONTRIBUTORS.md
docs/MODEL_LAB.md
docs/TOOL_LIFECYCLE.md
docs/WORKROOM_SECURITY.md
docs/WORKROOM_ARCHITECTURE.md
docs/WHALEFLOW_AUTHORING.md
docs/LEGACY_PATHS.md
docs/SANDBOX.md
docs/SKILL_INVOCATION_DESIGN.md
docs/CLAUDE.local.md
docs/memory/
benchmark_results/
docs/RELEASE_CHECKLIST.md
docs/RELEASE_RUNBOOK.md
docs/OPERATIONS_RUNBOOK.md
docs/PROVIDERS.md
docs/STABILITY_ANALYSIS.md
docs/AGENT_ETHOS.md

# ── Nix 配置 ──
flake.nix
nix/

# ── 部署配置 ──
deploy/
Dockerfile
.devcontainer/
.cnb.yml

# ── GitHub 模板/工作流 ──
.github/workflows/
.github/ISSUE_TEMPLATE/
.github/PULL_REQUEST_TEMPLATE.md
.github/APPROVED_CONTRIBUTORS
.github/AUTHOR_MAP
.github/CODEOWNERS
.github/dependabot.yml
.github/FUNDING.yml

# ── 资源文件（图片等，不影响代码理解）──
assets/

# ── 脚本文件（发布/部署/CI 脚本，不影响代码理解）──
scripts/

# ── 工作流定义（JS/Star 脚本）──
workflows/

# ── 临时/生成文件 ──
*.sh
*.cmd

# ── Git 内部目录 ──
.git/

# ── 项目本地配置 ──
.env.example
.mailmap
.gitattributes

# ============================================
# 保留（不排除）：
# - crates/              Rust 源代码（含 prompts/ 提示词模板）
# - docs/ 核心文档       ARCHITECTURE_CN.md, CONFIGURATION.md,
#                        SUBAGENTS.md, MCP.md, MODES.md, USAGE_CN.md,
#                        TOOL_SURFACE.md, KEYBINDINGS.md, MEMORY.md
# - config.example.toml  配置示例
# - AGENTS.md            AI 代理工作规范
# - CLAUDE.md            项目级 AI 指引
# - Cargo.toml           工作区配置
# ============================================
